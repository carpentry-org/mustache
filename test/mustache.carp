(load "main.carp")
(load "Test.carp")

(use-all Mustache Test)

(deftest test
  (assert-equal test
    "this is a strawberry"
    &(template "this is a {{ thing }}" &{@"thing" (Mustache.Str @"strawberry")})
    "simple templating works")
  (assert-equal test
    "this is a &lt;strawberry&gt;"
    &(template "this is a {{ thing }}"
               &{@"thing" (Mustache.Str @"<strawberry>")})
    "simple templating & escaping works")
  (assert-equal test
    "&amp; &lt; &gt; &quot; &#39;"
    &(template "{{ x }}" &{@"x" (Mustache.Str @"& < > \" '")})
    "escapes all five HTML-significant characters")
  (assert-equal test
    "this is a <strawberry>"
    &(template "this is a {{{ thing }}}"
               &{@"thing" (Mustache.Str @"<strawberry>")})
    "simple templating without escaping works")
  (assert-equal test
    "this is a "
    &(template "this is a {{{ thing }}}" &{})
    "simple templating with missing values works")
  (assert-equal test
    "this is a #lambda"
    &(template "this is a {{{ thing }}}"
               &{@"thing" (Mustache.Lambda (fn [x] x))})
    "simple templating with functions works")
  (assert-equal test "partial says: 'hi, mustache!
'" &(template "partial says: '{{> test/file }}'"
              &{@"name" (Mustache.Str @"mustache")}) "simple templating with partials works")
  (assert-equal test
    "this is an explosion!"
    &(template
      "this is an explosion{{# thing }}!{{/ thing }}"
      &{@"thing" (Mustache.Str @"!")})
    "simple sections with strings works")
  (assert-equal test
    "this is an "
    &(template
      "this is an {{# thing }}explosion!{{/ thing }}"
      &{@"thing" (Mustache.Str @"")})
    "simple sections with empty strings works")
  (assert-equal test
    "this is an explosion!"
    &(template
      "this is an {{# thing }}explosion{{/ thing }}"
      &{@"thing" (Mustache.Lambda (fn [x] (String.append &x "!")))})
    "simple sections with functions works")
  (assert-equal test
    "this is an "
    &(template
      "this is an {{{^ thing }}}inverted section{{/ thing }}"
      &{@"thing" (Mustache.Lambda (fn [x] x))})
    "simple inverted sections work I")
  (assert-equal test
    "this is an "
    &(template
      "this is an {{^ thing }}inverted section{{/ thing }}"
      &{@"thing" (Mustache.Str @"there")})
    "simple inverted sections work II")
  (assert-equal test
    "this is an inverted section"
    &(template "this is an {{^ thing }}inverted section{{/ thing }}" &{})
    "simple inverted sections work III")
  (assert-equal test
    "this is an inverted section"
    &(template
      "this is an {{^ thing }}inverted section{{/ thing }}"
      &{@"thing" (Mustache.Str @"")})
    "simple inverted sections work IV")
  (assert-equal test
    "this is an inverted section  with extras!"
    &(template
      "{{prelude}} {{^ thing }}inverted section{{/ thing }} {{#notthere}} i will vanish{{/notthere}} {{# extra }}with extras{{/ extra }}{{# bang }}!{{# band}}"
      &{@"thing" (Mustache.Str @"")
        @"extra" (Mustache.Str @"There")
        @"prelude" (Mustache.Str @"this is an")
        @"bang" (Mustache.Lambda id)})
    "complicated sections work")
  (assert-equal test
    "with switched tags!"
    &(template
      "{{=& &=}}&switched& tags&^inverted&!&/inverted&"
      &{@"switched" (Mustache.Str @"with switched")})
    "switching tags works")
  (assert-equal test
    "a b c "
    &(template "{{#items}}{{.}} {{/items}}"
               &{@"items" (Mustache.Lst
                   [(Box.init (Mustache.Str @"a"))
                    (Box.init (Mustache.Str @"b"))
                    (Box.init (Mustache.Str @"c"))])})
    "list iteration with dot")
  (assert-equal test
    "(empty)"
    &(template
      "{{#items}}x{{/items}}{{^items}}(empty){{/items}}"
      &{@"items" (Mustache.Lst [])})
    "empty list is falsy")
  (assert-equal test
    "Ada Grace "
    &(template "{{#users}}{{name}} {{/users}}"
               &{@"users" (Mustache.Lst
                   [(Box.init
                      (Mustache.Mp {@"name" (Box.init (Mustache.Str @"Ada"))}))
                    (Box.init
                      (Mustache.Mp {@"name" (Box.init (Mustache.Str @"Grace"))}))])})
    "list of object contexts")
  (assert-equal test
    "Carp is typed"
    &(template "{{#lang}}{{name}} is {{kind}}{{/lang}}"
               &{@"lang" (Mustache.Mp
                   {@"name" (Box.init (Mustache.Str @"Carp"))
                    @"kind" (Box.init (Mustache.Str @"typed"))})})
    "map as section context")
  (assert-equal test
    "outer-value"
    &(template "{{#inner}}{{outer}}{{/inner}}"
               &{@"outer" (Mustache.Str @"outer-value")
                 @"inner" (Mustache.Mp {})})
    "inner map falls through to outer context")
  (assert-equal test
    "x=12 y=34 "
    &(template
      "{{#outer}}{{name}}={{#nums}}{{.}}{{/nums}} {{/outer}}"
      &{@"outer" (Mustache.Lst
          [(Box.init
             (Mustache.Mp
               {@"name" (Box.init (Mustache.Str @"x"))
                @"nums" (Box.init
                  (Mustache.Lst
                    [(Box.init (Mustache.Str @"1"))
                     (Box.init (Mustache.Str @"2"))]))}))
           (Box.init
             (Mustache.Mp
               {@"name" (Box.init (Mustache.Str @"y"))
                @"nums" (Box.init
                  (Mustache.Lst
                    [(Box.init (Mustache.Str @"3"))
                     (Box.init (Mustache.Str @"4"))]))}))])})
    "nested list-in-map-in-list")
  (assert-equal test
    "[inherited]"
    &(template "{{#wrap}}[{{prelude}}]{{/wrap}}"
               &{@"wrap" (Mustache.Mp {})
                 @"prelude" (Mustache.Str @"inherited")})
    "outer context inherited through map section")
  (assert-equal test
    "hello world"
    &(template "hello {{! this is a comment }}world" &{})
    "comments are stripped")
  (assert-equal test
    "<strawberry>"
    &(template "{{& thing }}" &{@"thing" (Mustache.Str @"<strawberry>")})
    "explicit raw var with ampersand syntax")
  (assert-equal test
    "[]"
    &(template "[{{> no_such_file }}]" &{})
    "missing partial renders as empty")
  (assert-equal test
    "xy"
    &(template "{{#foo}}x{{/bar}}y{{/foo}}" &{@"foo" (Mustache.Str @"present")})
    "mismatched close tag inside section is ignored")
  (assert-equal test "" &(template "" &{}) "empty template renders as empty")
  (assert-equal test
    ""
    &(template "{{missing}}" &{})
    "missing var renders as empty")
  (assert-equal test
    "hi"
    &(template "{{=foo=}}hi" &{})
    "malformed set-delimiter is consumed without crashing")
  (assert-equal test
    "#lambda#lambda"
    &(template "{{#fs}}{{.}}{{/fs}}"
               &{@"fs" (Mustache.Lst
                   [(Box.init (Mustache.Lambda (fn [x] x)))
                    (Box.init (Mustache.Lambda (fn [x] x)))])})
    "list of lambdas stringifies each as #lambda")
  ; standalone tag whitespace handling
  (assert-equal test "Begin
End
" &(template "Begin
  {{! standalone comment }}
End
" &{}) "standalone comment strips entire line")
  (assert-equal test
    "hello world"
    &(template "hello {{! inline comment }}world" &{})
    "inline comment preserves surrounding text")
  (assert-equal test "|
|" &(template "|
{{# bool }}
{{/ bool }}
|" &{@"bool" (Mustache.Str @"true")}) "standalone section open and close strip their lines")
  (assert-equal test "|
Content
|" &(template "|
{{# bool }}
Content
{{/ bool }}
|" &{@"bool" (Mustache.Str @"true")}) "standalone section preserves body content")
  (assert-equal test "|
=" &(template "|
{{= | | =}}
|content|" &{@"content" (Mustache.Str @"=")}) "standalone set-delimiter strips its line")
  (assert-equal test "" &(template "  {{! comment }}
" &{}) "standalone comment at start strips line including newline")
  (assert-equal test "!
" &(template "!
  {{! comment }}" &{}) "standalone comment at end strips line without trailing newline")
  (assert-equal test "|
-1-
-2-
|" &(template "|
{{# items }}
-{{.}}-
{{/ items }}
|" &{@"items" (Mustache.Lst
       [(Box.init (Mustache.Str @"1")) (Box.init (Mustache.Str @"2"))])}) "standalone section with list iteration")
  (assert-equal test "|
^
|" &(template "|
{{^ bool }}
^
{{/ bool }}
|" &{@"bool" (Mustache.Str @"")}) "standalone inverted section strips its lines")
  (assert-equal test "Begin


End
" &(template "Begin

{{! comment }}

End
" &{}) "standalone comment with surrounding blank lines preserves blanks")
  (assert-equal test "Begin
hi, world!
End
" &(template "Begin
  {{> test/file }}
End
" &{@"name" (Mustache.Str @"world")}) "standalone partial strips its line")
  ; dotted-name resolution
  (assert-equal test
    "Ada"
    &(template "{{user.name}}"
               &{@"user" (Mustache.Mp {@"name" (Box.init (Mustache.Str @"Ada"))})})
    "dotted interpolation resolves a nested map value")
  (assert-equal test
    "deep"
    &(template "{{a.b.c}}"
               &{@"a" (Mustache.Mp
                   {@"b" (Box.init
                      (Mustache.Mp {@"c" (Box.init (Mustache.Str @"deep"))}))})})
    "dotted interpolation resolves arbitrary depth")
  (assert-equal test
    "&lt;x&gt;"
    &(template "{{a.b}}"
               &{@"a" (Mustache.Mp {@"b" (Box.init (Mustache.Str @"<x>"))})})
    "dotted interpolation escapes like a plain var")
  (assert-equal test
    "<x>"
    &(template "{{{a.b}}}"
               &{@"a" (Mustache.Mp {@"b" (Box.init (Mustache.Str @"<x>"))})})
    "dotted interpolation is not escaped in triple-mustache")
  (assert-equal test
    "Carp is typed"
    &(template "{{#a.b}}{{name}} is {{kind}}{{/a.b}}"
               &{@"a" (Mustache.Mp
                   {@"b" (Box.init
                      (Mustache.Mp
                        {@"name" (Box.init (Mustache.Str @"Carp"))
                         @"kind" (Box.init (Mustache.Str @"typed"))}))})})
    "dotted section pushes the nested map as a context frame")
  (assert-equal test
    "1 2 "
    &(template "{{#a.nums}}{{.}} {{/a.nums}}"
               &{@"a" (Mustache.Mp
                   {@"nums" (Box.init
                      (Mustache.Lst
                        [(Box.init (Mustache.Str @"1"))
                         (Box.init (Mustache.Str @"2"))]))})})
    "dotted section resolving to a list iterates")
  (assert-equal test
    "x"
    &(template "x{{a.missing.deep}}"
               &{@"a" (Mustache.Mp {@"name" (Box.init (Mustache.Str @"Ada"))})})
    "dotted name through a missing intermediate renders empty")
  (assert-equal test
    "x"
    &(template "x{{#a.missing}}body{{/a.missing}}"
               &{@"a" (Mustache.Mp {@"name" (Box.init (Mustache.Str @"Ada"))})})
    "dotted section with a missing key is skipped")
  (assert-equal test
    "no b"
    &(template "{{^a.b}}no b{{/a.b}}"
               &{@"a" (Mustache.Mp {@"name" (Box.init (Mustache.Str @"Ada"))})})
    "inverted dotted section renders when the name is missing")
  (assert-equal test
    ""
    &(template "{{a.b}}" &{@"a" (Mustache.Str @"plain")})
    "dotted name into a non-map value renders empty")
  (assert-equal test
    ""
    &(template "{{#a}}{{b.c}}{{/a}}"
               &{@"a" (Mustache.Mp
                   {@"b" (Box.init
                      (Mustache.Mp (the (Map String (Box Mustache)) {})))})
                 @"b" (Mustache.Mp {@"c" (Box.init (Mustache.Str @"ERROR"))})})
    "context precedence: dotted head fixes to the section frame b (empty), not top-level b.c")
  (assert-equal test
    ""
    &(template "{{a.b}}" &{@"a.b" (Mustache.Str @"ERROR")})
    "a literal a.b map key is never matched by dotted {{a.b}} (name is split first)"))
